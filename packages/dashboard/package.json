{
	"name": "@geo-agent/dashboard",
	"version": "0.1.0",
	"description": "GEO Agent localhost web dashboard",
	"type": "module",
	"main": "dist/server.js",
	"types": "dist/server.d.ts",
	"exports": {
		".": {
			"import": "./dist/server.js",
			"types": "./dist/server.d.ts"
