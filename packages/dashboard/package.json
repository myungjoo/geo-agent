{
	"name": "@geo-agent/dashboard",
	"version": "0.1.0",
	"description": "GEO Agent localhost web dashboard",
	"type": "module",
	"main": "dist/server.js",
	"types": "dist/server.d.ts",
	"exports": {
		".": {
			"import": "./dist/server.js",
			"types": "./dist/server.d.ts"
		}
	},
	"scripts": {
		"build": "tsc -b tsconfig.build.json && npm run postbuild",
		"postbuild": "npm run copy-assets && npm run write-build-info",
		"copy-assets": "node -e \"const fs=require('fs'),p=require('path');const s=p.join('src','ui'),d=p.join('dist','ui');fs.mkdirSync(d,{recursive:true});fs.readdirSync(s).forEach(f=>fs.copyFileSync(p.join(s,f),p.join(d,f)));\"",
		"write-build-info": "node -e \"const{execSync:e}=require('child_process'),fs=require('fs');try{const sha=e('git rev-parse HEAD',{encoding:'utf-8'}).trim();fs.writeFileSync('dist/build-info.json',JSON.stringify({sha,short:sha.slice(0,7),date:e('git log -1 --format=%ci',{encoding:'utf-8'}).trim(),buildTime:new Date().toISOString()}));}catch{fs.writeFileSync('dist/build-info.json',JSON.stringify({sha:'unknown',short:'unknown',date:'unknown',buildTime:new Date().toISOString()}));}\"",
		"dev": "node --import tsx src/server.ts",
		"test": "vitest run",
		"clean": "rimraf dist .tsbuildinfo"
	},
	"dependencies": {
		"@geo-agent/core": "*",
		"@geo-agent/skills": "*",
		"@hono/node-server": "^1.13.0",
		"hono": "^4.6.0"
	},
	"devDependencies": {
		"tsx": "^4.19.0"
	}
}
