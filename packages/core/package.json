{
  "name": "@geo-agent/core",
  "version": "0.1.0",
  "description": "GEO Agent System core logic, schemas, and infrastructure",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./models": {
      "import": "./dist/models/index.js",
      "types": "./dist/models/index.d.ts"
    },
    "./prompts/prompt-loader.js": {
      "import": "./dist/prompts/prompt-loader.js",
      "types": "./dist/prompts/prompt-loader.d.ts"
    },
    "./prompts/defaults.js": {
      "import": "./dist/prompts/defaults.js",
      "types": "./dist/prompts/defaults.d.ts"
    },
    "./llm/provider-config.js": {
      "import": "./dist/llm/provider-config.js",
      "types": "./dist/llm/provider-config.d.ts"
    },
    "./llm/geo-llm-client.js": {
      "import": "./dist/llm/geo-llm-client.js",
      "types": "./dist/llm/geo-llm-client.d.ts"
    },
    "./prompts/template-engine.js": {
      "import": "./dist/prompts/template-engine.js",
      "types": "./dist/prompts/template-engine.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "test": "vitest run",
    "clean": "rimraf dist .tsbuildinfo"
  },
  "dependencies": {
    "@libsql/client": "^0.14.0",
    "drizzle-orm": "^0.35.0",
    "pino": "^9.0.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/uuid": "^10.0.0",
    "drizzle-kit": "^0.25.0"
  }
}
