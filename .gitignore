# Run directory - 실행 테스트 환경 (설치/실행 결과물이 git에 영향을 주지 않도록 격리)
run/

# Node.js
node_modules/
dist/
*.tsbuildinfo

# TypeScript build outputs in src/ (safety net — should only exist in dist/)
packages/*/src/**/*.js
packages/*/src/**/*.js.map
packages/*/src/**/*.d.ts
packages/*/src/**/*.d.ts.map
tests/**/*.js
tests/**/*.js.map
tests/**/*.d.ts
tests/**/*.d.ts.map

# tsc-compiled config files (source is .ts)
vitest.config.js
vitest.config.d.ts
vitest.config.js.map
vitest.config.d.ts.map
packages/*/vitest.config.js
packages/*/vitest.config.d.ts
packages/*/vitest.config.js.map
packages/*/vitest.config.d.ts.map
packages/*/drizzle.config.js
packages/*/drizzle.config.d.ts
packages/*/drizzle.config.js.map
packages/*/drizzle.config.d.ts.map

# Test coverage
coverage/

# Environment
.env
.env.*
!.env.example

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Claude Code local settings
.claude/settings.local.json

# Workspace runtime data
workspace/data/
workspace/skills/
