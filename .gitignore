# Run directory - 실행 테스트 환경 (설치/실행 결과물이 git에 영향을 주지 않도록 격리)
run/

# Node.js
node_modules/
dist/
*.tsbuildinfo

# TypeScript build outputs in src/ (should only exist in dist/)
packages/*/src/**/*.js
packages/*/src/**/*.d.ts
packages/*/src/**/*.js.map
*.config.js
*.config.d.ts

# Test coverage
coverage/

# Environment
.env
.env.*
!.env.example

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Claude Code local settings
.claude/settings.local.json

# Workspace runtime data
workspace/data/
workspace/skills/
