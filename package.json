{
	"name": "geo-agent",
	"version": "0.1.0",
	"private": true,
	"description": "GEO (Generative Engine Optimization) Agent System",
	"workspaces": ["packages/*"],
	"scripts": {
		"prebuild": "npm run clean --workspaces",
		"build": "tsc -b tsconfig.build.json --force",
		"start": "node --import tsx packages/cli/src/index.ts start",
		"dev": "npm run dev --workspace=packages/dashboard",
		"analyze": "node --import tsx packages/cli/src/index.ts analyze",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"pretest": "npm run build",
		"test": "vitest run",
		"test:e2e": "vitest run --config tests/e2e/vitest.config.e2e.ts",
		"test:llm": "vitest run --config tests/llm-integration/vitest.config.llm.ts",
		"test:all": "npm test && npm run test:e2e",
		"ci": "npm install && npm run build && npm test",
		"clean": "npm run clean --workspaces"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.0",
		"rimraf": "^6.1.3",
		"typescript": "^5.7.0",
		"vitest": "^2.0.0"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"dependencies": {
		"@mariozechner/pi-ai": "^0.61.1"
	}
}
