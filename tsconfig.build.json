{
	"compilerOptions": {
		"target": "ES2022",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"composite": true,
		"incremental": true,
		"resolveJsonModule": true
	},
	"references": [
		{ "path": "packages/core/tsconfig.build.json" },
		{ "path": "packages/skills/tsconfig.build.json" },
		{ "path": "packages/dashboard/tsconfig.build.json" },
		{ "path": "packages/cli/tsconfig.build.json" }
	],
	"files": []
}
