{
	"$schema": "https://biomejs.dev/schemas/1.9.0/schema.json",
	"files": {
		"ignore": [
			"dist/**",
			"node_modules/**",
			"*.tsbuildinfo",
			"drizzle/**",
			".claude/**",
			"**/*.d.ts",
			"**/*.d.ts.map",
			"**/*.js",
			"**/*.js.map",
			"vitest.config.js",
			"packages/core/drizzle.config.js"
		]
	},
	"organizeImports": {
		"enabled": true
	},
	"formatter": {
		"enabled": true,
		"lineEnding": "lf",
		"indentStyle": "tab",
		"indentWidth": 2,
		"lineWidth": 100
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"style": {
				"noNonNullAssertion": "off"
			}
		}
	},
	"overrides": [
		{
			"include": ["**/*.test.ts"],
			"linter": {
				"rules": {
					"suspicious": {
						"noExplicitAny": "off"
					}
				}
			}
		},
		{
			"include": [
				"**/agents/analysis/tools.ts",
				"**/agents/pipeline/pipeline-runner.ts",
				"**/llm/pi-ai-bridge.ts"
			],
			"linter": {
				"rules": {
					"suspicious": {
						"noExplicitAny": "off"
					}
				}
			}
		},
		{
			"include": ["packages/dashboard/src/auth.test.ts"],
			"linter": {
				"rules": {
					"performance": {
						"noDelete": "off"
					}
				}
			}
		}
	],
	"javascript": {
		"formatter": {
			"quoteStyle": "double",
			"semicolons": "always"
		}
	}
}
